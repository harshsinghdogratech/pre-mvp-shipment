DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/shipment
# Set to true for local smoke tests without PostgreSQL (creates ./shipment.db).
USE_SQLITE=false
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480
CORS_ORIGINS=http://localhost:3000
